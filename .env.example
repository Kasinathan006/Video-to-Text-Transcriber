# VoxDoc AI Studio — Cloud & Local Environment Secrets
# Copy this file to `.env` (for local) or add these to Streamlit Cloud Secrets (for cloud).

# 1. Personal Workspace Security Lock ("naa matum use pannura mathuri")
# Set your personal passcode/PIN here. Only anyone who knows this password can unlock the app!
# Default if left blank is: mohan
VOXDOC_ADMIN_PASSWORD=mohan

# 2. Sarvam AI API Key (Best for Tamil / Hindi / Indian Languages - Cloud GPU)
# Get a key at: https://dashboard.sarvam.ai
SARVAM_API_KEY=

# 3. Groq API Key (100% FREE & Ultra-Fast Cloud Whisper-large-v3)
# Get a free key instantly at: https://console.groq.com
GROQ_API_KEY=

# 4. Port for local REST API server (optional, default 8000)
VOXDOC_PORT=8000
